{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build sfml",
      "type": "shell",
      "command": "g++",
      "args": [
        "-std=c++17",
        "main.cpp",
        "Game.cpp",
        "Player.cpp",
        "Monster.cpp",
        "-o",
        "testfile/app.exe",
        "-I",
        "SFML-3.0.2/include",
        "-L",
        "SFML-3.0.2/lib",
        "-lsfml-graphics",
        "-lsfml-window",
        "-lsfml-system"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": [
        "$gcc"
      ]
    }
  ]
}